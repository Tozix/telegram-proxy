// Prisma schema for the Telegram proxy (Prisma 7).
// Schema is applied with `prisma db push` (no migration files) — see README.
// The connection URL lives in prisma.config.ts; the runtime uses the
// @prisma/adapter-pg driver adapter (no Rust query engine).

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  user
}

/// Users of the management API / web UI. `admin` sees everything; `user` manages
/// only their own bots. New self-registrations are `user` and must verify email.
model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  passwordHash       String    @map("password_hash")
  role               UserRole  @default(user)
  /// Null until the email is confirmed. Admins are created already-verified.
  emailVerifiedAt    DateTime? @map("email_verified_at")
  /// One-time email-confirmation token (cleared after verification).
  verificationToken  String?   @unique @map("verification_token")
  verificationSentAt DateTime? @map("verification_sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  bots Bot[]

  @@map("users")
}

/// A registered Telegram bot whose webhook traffic this service proxies.
model Bot {
  id               String    @id @default(uuid()) @db.Uuid
  /// Owner. Null = legacy/orphan bot (visible only to admins). Cascade on delete.
  userId           String?   @map("user_id") @db.Uuid
  user             User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  /// Telegram bot token (`123456:ABC...`). Kept private — never serialized.
  token            String    @unique
  /// Numeric Telegram id of the bot (from getMe).
  telegramBotId    BigInt?   @map("telegram_bot_id")
  /// @-username of the bot (from getMe).
  username         String?
  /// Secret used both as the URL path segment and the Telegram secret_token header.
  webhookSecret    String    @unique @map("webhook_secret")
  /// Real backend URL that should receive forwarded updates.
  targetWebhookUrl String    @map("target_webhook_url")
  /// Optional Telegram allowed_updates list passed to setWebhook (jsonb; null = omit).
  allowedUpdates   Json?     @map("allowed_updates")
  isActive         Boolean   @default(true) @map("is_active")
  lastWebhookSetAt DateTime? @map("last_webhook_set_at")
  webhookError     String?   @map("webhook_error")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("bots")
}

/// Audit record of one incoming webhook delivery and its forwarding.
model DeliveryLog {
  id             String   @id @default(uuid()) @db.Uuid
  botId          String?  @map("bot_id") @db.Uuid
  updateId       String?  @map("update_id")
  targetUrl      String   @map("target_url")
  requestBytes   Int      @default(0) @map("request_bytes")
  responseStatus Int?     @map("response_status")
  success        Boolean  @default(false)
  errorMessage   String?  @map("error_message")
  durationMs     Int      @default(0) @map("duration_ms")
  /// Номер попытки доставки (1 = первая отправка, далее — повторы).
  attempt        Int      @default(1) @map("attempt")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([botId, createdAt])
  @@map("delivery_logs")
}
