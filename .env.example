# ---- App ----
NODE_ENV=development
PORT=3000
# Public origin Telegram uses to reach this service (used to build webhook URLs)
PUBLIC_BASE_URL=https://telegram.crossmark.ru

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=telegram_proxy
# Auto-create/update tables from entities. Fine for dev; use migrations in prod.
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_SSL=false

# ---- Auth (JWT) ----
# MUST be at least 16 chars. Generate e.g.: openssl rand -hex 32
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Initial admin, seeded on first boot if the users table is empty
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# ---- Telegram ----
TELEGRAM_API_BASE=https://api.telegram.org

# ---- Proxy behaviour ----
# Allow proxying Bot API calls for tokens NOT registered in the admin (open proxy). Keep false.
PROXY_ALLOW_UNREGISTERED=false
PROXY_TIMEOUT_MS=30000
WEBHOOK_FORWARD_TIMEOUT_MS=25000
MAX_UPLOAD_MB=50

# ---- Admin frontend (Next.js, docker-compose) ----
# Host port for the admin UI (container listens on 3001 internally)
FRONTEND_PORT=8080
# Set to "true" only when the admin UI is served over HTTPS
COOKIE_SECURE=false
