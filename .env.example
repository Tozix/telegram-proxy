# ---- App ----
NODE_ENV=development
# Port the backend listens on (also the container port in docker-compose).
PORT=3085
# Public origin Telegram uses to reach this service (used to build webhook URLs)
PUBLIC_BASE_URL=https://proxy.example.com
# Public origin of the web UI (used in email links, e.g. verification).
# Single-domain deploy behind nginx: same as PUBLIC_BASE_URL. Local dev: http://localhost:5085
APP_URL=https://proxy.example.com

# ---- Mail (SMTP) — for registration email confirmation ----
# Leave MAIL_HOST empty to disable sending (links are logged instead — handy in dev).
MAIL_HOST=
MAIL_PORT=465
MAIL_SSL=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Telegram Proxy

# ---- Database (PostgreSQL via Prisma) ----
# Prisma connection string used by the app AND the `prisma` CLI (db push / generate).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_proxy?schema=public
# The vars below are used ONLY by docker-compose: to configure the bundled
# Postgres container and to compose the in-compose DATABASE_URL. For a non-Docker
# run, ignore them and set DATABASE_URL above.
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=telegram_proxy

# ---- Auth (JWT) ----
# MUST be at least 16 chars. Generate e.g.: openssl rand -hex 32
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Initial admin, seeded on first boot if the users table is empty
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# ---- Redis (cache for the proxy open-relay guard; DB stays source of truth) ----
# Either set REDIS_URL, or the discrete REDIS_HOST/PORT/PASSWORD/DB below.
# REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=tgproxy:
# TTL (seconds) of the "is this token registered?" cache used by the proxy guard
REDIS_TOKEN_CACHE_TTL=30

# ---- Telegram ----
TELEGRAM_API_BASE=https://api.telegram.org

# ---- Proxy behaviour ----
# Allow proxying Bot API calls for tokens NOT registered in the admin (open proxy). Keep false.
PROXY_ALLOW_UNREGISTERED=false
PROXY_TIMEOUT_MS=30000
WEBHOOK_FORWARD_TIMEOUT_MS=25000
# Сколько раз ПОВТОРНО отправить вебхук на бэкенд, если он не вернул 2xx (плюс к первой отправке)
WEBHOOK_RETRY_ATTEMPTS=3
# Базовая пауза между повторами (мс); растёт экспоненциально: 500, 1000, 2000…
WEBHOOK_RETRY_DELAY_MS=500
MAX_UPLOAD_MB=50

# ---- Ports (docker-compose) ----
# Container/app ports: PORT (backend, above) and FRONTEND_PORT (frontend below).
# Host ports published to the machine (set to avoid clashes with other apps):
APP_HOST_PORT=3085
FRONTEND_HOST_PORT=5085

# ---- Admin frontend (Next.js) ----
# Port the frontend listens on (also the container port in docker-compose).
FRONTEND_PORT=5085
# Set to "true" only when the admin UI is served over HTTPS
COOKIE_SECURE=false
