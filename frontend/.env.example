# Server-side base URL of the NestJS backend (browser never sees this).
# Local dev:           http://localhost:3000
# docker-compose:      http://app:3000
API_URL=http://localhost:3000

# Port the Next.js server listens on
PORT=3001

# Set to "true" only when the admin UI is served over HTTPS (marks the auth
# cookie Secure). Leave false for plain-HTTP access.
COOKIE_SECURE=false
