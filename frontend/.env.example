# Server-side base URL of the NestJS backend (browser never sees this).
# Local dev:           http://localhost:3085
# docker-compose:      http://app:3085
API_URL=http://localhost:3085

# Port the Next.js server listens on
PORT=5085

# Set to "true" only when the admin UI is served over HTTPS (marks the auth
# cookie Secure). Leave false for plain-HTTP access.
COOKIE_SECURE=false

# ---- Public (exposed to the browser) ----
# Shown in the landing/docs code examples. Set to your proxy's public origin.
NEXT_PUBLIC_PROXY_HOST=https://proxy.example.com
# Where the Swagger UI is reachable from the browser.
# Local dev: http://localhost:3085/docs. Behind nginx (prod): /docs on the same domain.
NEXT_PUBLIC_SWAGGER_URL=/docs
# Repository link shown in the header.
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-org/telegram-proxy
