# =============================================================================
#  nginx reverse proxy + TLS termination for the Telegram proxy
#  (domain: proxy.example.com)
#
#  Traffic map:
#    Telegram          ─▶ https://proxy.example.com/webhook/<secret>     ─▶ backend
#    bot backend (RU)  ─▶ https://proxy.example.com/bot<token>/<method>  ─▶ backend
#    operator (you)    ─▶ https://proxy.example.com/        (admin UI)   ─▶ frontend
#
#  Defaults: backend on 127.0.0.1:3085, admin UI on 127.0.0.1:5085 — the host
#  port mappings from docker-compose.yml (APP_HOST_PORT / FRONTEND_HOST_PORT).
#  Change the upstreams below if you set different ports.
#
#  Install:
#    sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/telegram-proxy
#    sudo ln -s /etc/nginx/sites-available/telegram-proxy /etc/nginx/sites-enabled/
#    sudo nginx -t && sudo systemctl reload nginx
#  TLS cert (Let's Encrypt):
#    sudo certbot --nginx -d proxy.example.com
# =============================================================================

upstream tg_backend  { server 127.0.0.1:3085; keepalive 32; }
upstream tg_frontend { server 127.0.0.1:5085; keepalive 32; }

# --- HTTP: serve ACME challenge, redirect everything else to HTTPS ---
server {
    listen 80;
    listen [::]:80;
    server_name proxy.example.com;

    location /.well-known/acme-challenge/ { root /var/www/certbot; }
    location / { return 301 https://$host$request_uri; }
}

# --- HTTPS ---
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name proxy.example.com;

    ssl_certificate     /etc/letsencrypt/live/proxy.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/proxy.example.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Must be >= MAX_UPLOAD_MB (default 50) so multipart uploads (sendPhoto,
    # sendDocument, ...) and large file downloads pass through.
    client_max_body_size 60m;

    # Headers applied to every proxied request.
    proxy_http_version 1.1;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Connection        "";
    # The X-Telegram-Bot-Api-Secret-Token header is forwarded automatically.

    # ------------------------------------------------------------------ #
    #  Telegram-facing & admin-API surfaces  ->  NestJS backend          #
    # ------------------------------------------------------------------ #

    # Transparent Bot API proxy: /bot<token>/<method> and /file/bot<token>/<path>.
    # The numeric bot id is always followed by ':' (e.g. /bot123456:AA.../getMe),
    # so this never collides with the admin UI's /bots pages.
    location ~ ^/(?:file/)?bot[0-9]+: {
        proxy_pass http://tg_backend;
        proxy_request_buffering off;   # stream large multipart uploads
        proxy_buffering         off;   # stream large file downloads
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }

    # Inbound webhooks from Telegram.
    location ^~ /webhook/ { proxy_pass http://tg_backend; }

    # Admin REST API, auth, Swagger UI and the liveness probe.
    location ^~ /api/  { proxy_pass http://tg_backend; }
    location ^~ /auth  { proxy_pass http://tg_backend; }
    location ^~ /docs  { proxy_pass http://tg_backend; }
    location = /health { proxy_pass http://tg_backend; }

    # ------------------------------------------------------------------ #
    #  Everything else  ->  Next.js admin UI                             #
    # ------------------------------------------------------------------ #
    location / {
        proxy_pass http://tg_frontend;
    }

    # ------------------------------------------------------------------ #
    #  ALTERNATIVE: serve the admin UI on a separate subdomain instead   #
    #  of mixing it with the public proxy host. Drop the `location /`     #
    #  block above, point this server only at the backend, and add a      #
    #  second server block:                                               #
    #                                                                     #
    #    server {                                                         #
    #        listen 443 ssl;                                              #
    #        server_name admin.proxy.example.com;                     #
    #        ssl_certificate ...; ssl_certificate_key ...;                #
    #        location / { proxy_pass http://tg_frontend; }               #
    #    }                                                                #
    #                                                                     #
    #  Remember COOKIE_SECURE=true since the admin is served over HTTPS.  #
    # ------------------------------------------------------------------ #
}
